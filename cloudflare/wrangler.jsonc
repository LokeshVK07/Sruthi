{
  "name": "sruthi",
  "compatibility_date": "2026-04-08",
  "main": "src/worker.js",
  "assets": {
    "directory": "public",
    "binding": "ASSETS"
  },
  "vars": {
    "CATALOG_LANGUAGE": "tamil",
    "TELUGU_API_ORIGIN": "https://sruthi-telugu.vklokesh70.workers.dev",
    "SYNC_FEED_URL": "https://www.masstamilan.dev/sruthi-sync.json"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "sruthi-db",
      "database_id": "7e7f8f48-5f15-4ac8-bec0-37a899ddb33b"
    }
  ],
  "kv_namespaces": [
    {
      "binding": "TOKEN_CACHE",
      "id": "85855aff55d44d2db2effa99d69b0bdf"
    }
  ],
  "services": [
    {
      "binding": "TELUGU_SERVICE",
      "service": "sruthi-telugu"
    }
  ]
}